{
  "name": "aq_backend",
  "version": "1.0.0",
  "description": "This tool will check AirQuality around you and prompt about it",
  "main": "start.ts",
  "scripts": {
    "cc": "npx prettier --write ./src/",
    "ct": "npx prettier --write ./test/",
    "start": "ts-node ./src/start.ts",
    "build": "tsc -p .",
    "dev": "nodemon -r tsconfig-paths/register src/",
    "test": "mocha --check-leaks -r tsconfig-paths/register ts-node/register \"test/**/*.spec.ts\""
  },
  "keywords": [
    "Air",
    "Quality",
    "Control"
  ],
  "author": "silassentinel",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.18.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.3.0",
    "tslib": "^2.8.1",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.1",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "chai": "^6.2.2",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.32.0",
    "mocha": "^11.7.6",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.5",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  }
}
